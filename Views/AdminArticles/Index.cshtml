@model List<CmsBackend.Models.Article>

@{
    ViewData["Title"] = "Manage Articles";
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
<script>
    tailwind.config = {
        darkMode: "class",
        important: '.admin-articles-page',
        corePlugins: {
            preflight: false,
        },
        theme: {
            extend: {
                colors: {
                    primary: "#a899ff",
                    "primary-hover": "#9282f0",
                    "background-light": "#fcfdff",
                    "background-dark": "#111827",
                    "card-light": "#ffffff",
                    "card-dark": "#1f2937",
                    "text-main-light": "#0f172a",
                    "text-main-dark": "#f3f4f6",
                    "text-muted-light": "#64748b",
                    "text-muted-dark": "#9ca3af",
                    "border-light": "#e2e8f0",
                    "border-dark": "#374151",
                    "danger": "#ef4444",
                    "danger-hover": "#dc2626",
                },
                fontFamily: {
                    display: ["Inter", "sans-serif"],
                    sans: ["Inter", "sans-serif"],
                },
                borderRadius: {
                    DEFAULT: "0.75rem",
                },
                boxShadow: {
                    'subtle': '0 1px 2px 0 rgba(0, 0, 0, 0.05)',
                    'soft': '0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.02)',
                }
            },
        },
    };
</script>
<style>
    .admin-articles-page * {
        font-family: 'Inter', sans-serif;
    }
</style>

<div class="admin-articles-page" style="font-family: 'Inter', sans-serif;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full space-y-6">

        <!-- Main Card -->
        <div class="bg-card-light dark:bg-card-dark rounded-xl border border-border-light dark:border-border-dark p-6 md:p-8 shadow-soft transition-colors duration-200">

            <!-- Header Row -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                <div>
                    <h1 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mb-1">Manage Articles</h1>
                    <p class="text-text-muted-light dark:text-text-muted-dark text-sm">Create, edit, and delete content for the platform.</p>
                </div>
                <a href="@Url.Action("Create", "AdminArticles")"
                   class="inline-flex items-center justify-center px-4 py-2 bg-violet-400 hover:bg-primary-hover text-white text-sm font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary shadow-sm no-underline">
                    Create Article
                </a>
            </div>

            <!-- Search Bar -->
            <div class="relative">
                <input id="searchInput"
                       class="block w-full pl-10 pr-3 py-2.5 border border-border-light dark:border-border-dark rounded-lg leading-5 bg-background-light dark:bg-background-dark text-text-main-light dark:text-text-main-dark placeholder-text-muted-light dark:placeholder-text-muted-dark focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary sm:text-sm transition-colors"
                       placeholder="Search by title" type="text" />
            </div>

            <!-- Count & Sort Row -->
            <div class="mt-4 flex justify-between items-center">
                <span id="articleCount" class="text-xs font-semibold px-2.5 py-1 rounded-full bg-violet-100 dark:bg-blue-900/30 text-blue-500 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                    @Model.Count article@(Model.Count != 1 ? "s" : "") found
                </span>
                <div class="flex items-center space-x-2 text-sm text-text-muted-light dark:text-text-muted-dark">
                    <span>Sort by:</span>
                    <select id="sortSelect" class="text-sm py-1 pl-2 pr-8 border-none bg-transparent focus:ring-0 font-medium text-text-main-light dark:text-text-main-dark cursor-pointer">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                        <option value="title">Title A-Z</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Article Cards -->
        @if (Model.Count == 0)
        {
            <div class="bg-card-light dark:bg-card-dark rounded-xl border border-border-light dark:border-border-dark p-8 shadow-soft text-center">
                <span class="material-icons text-5xl text-text-muted-light dark:text-text-muted-dark mb-3 block">article</span>
                <p class="text-text-muted-light dark:text-text-muted-dark text-sm">No articles found.</p>
                <a href="@Url.Action("Create", "AdminArticles")"
                   class="inline-flex items-center justify-center mt-4 px-4 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-medium rounded-lg transition-colors no-underline">
                    <span class="material-icons text-sm mr-2">add</span>
                    Create your first article
                </a>
            </div>
        }
        else
        {
            <div class="space-y-4" id="articleList">
                @foreach (var article in Model)
                {
                    <div class="article-card bg-card-light dark:bg-card-dark rounded-xl border border-border-light dark:border-border-dark p-5 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
                         data-title="@article.Title" data-author="@article.AuthorName" data-date="@article.CreatedAtUtc.ToString("o")">
                        <div class="flex-grow min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark truncate">@article.Title</h3>
                            </div>
                            <div class="text-sm text-text-muted-light dark:text-text-muted-dark flex flex-wrap items-center gap-x-2">
                                <span class="font-medium text-text-main-light dark:text-text-main-dark">By @article.AuthorName</span>
                                <span class="text-xs">•</span>
                                <span>@article.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd, h:mm tt")</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 w-full sm:w-auto mt-2 sm:mt-0">
                            <a href="@Url.Action("Edit", "AdminArticles", new { id = article.Id })"
                               class="flex-1 sm:flex-none inline-flex items-center justify-center px-4 py-2 bg-primary/10 dark:bg-primary/20 hover:bg-primary/20 dark:hover:bg-primary/30 text-primary dark:text-purple-300 text-sm font-medium rounded-lg transition-colors no-underline">
                                Edit
                            </a>
                            <form method="post" action="@Url.Action("Delete", "AdminArticles", new { id = article.Id })" style="display:inline;" class="flex-1 sm:flex-none">
                                <button type="submit"
                                        class="w-full inline-flex items-center justify-center px-4 py-2 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 text-danger dark:text-red-400 text-sm font-medium rounded-lg transition-colors border border-transparent hover:border-red-200 dark:hover:border-red-800"
                                        onclick="return confirm('Are you sure you want to delete this article?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Client-side search filtering
        const searchInput = document.getElementById('searchInput');
        const articleList = document.getElementById('articleList');
        const articleCount = document.getElementById('articleCount');
        const sortSelect = document.getElementById('sortSelect');

        function getCards() {
            return articleList ? Array.from(articleList.querySelectorAll('.article-card')) : [];
        }

        function filterAndSort() {
            const query = searchInput.value.toLowerCase();
            const cards = getCards();
            let visibleCount = 0;

            cards.forEach(card => {
                const title = (card.dataset.title || '').toLowerCase();
                const author = (card.dataset.author || '').toLowerCase();
                const matches = title.includes(query) || author.includes(query);
                card.style.display = matches ? '' : 'none';
                if (matches) visibleCount++;
            });

            if (articleCount) {
                articleCount.textContent = visibleCount + ' article' + (visibleCount !== 1 ? 's' : '') + ' found';
            }

            // Sort visible cards
            const sortValue = sortSelect.value;
            const sorted = cards.slice().sort((a, b) => {
                if (sortValue === 'newest') {
                    return new Date(b.dataset.date) - new Date(a.dataset.date);
                } else if (sortValue === 'oldest') {
                    return new Date(a.dataset.date) - new Date(b.dataset.date);
                } else if (sortValue === 'title') {
                    return (a.dataset.title || '').localeCompare(b.dataset.title || '');
                }
                return 0;
            });

            sorted.forEach(card => articleList.appendChild(card));
        }

        if (searchInput) searchInput.addEventListener('input', filterAndSort);
        if (sortSelect) sortSelect.addEventListener('change', filterAndSort);
    </script>
}
