@page
@model LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Mini-CMS Admin Login</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#a78bfa",
                        "background-light": "#f8fafc",
                        "background-dark": "#0f172a",
                        "card-light": "#ffffff",
                        "card-dark": "#1e293b",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        'xl': '1rem',
                        '2xl': '1.5rem',
                    },
                    boxShadow: {
                        'soft': '0 4px 20px -2px rgba(0, 0, 0, 0.05)',
                    }
                },
            },
        };
    </script>
    <style>
        @@keyframes fade-in-up {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-up {
            animation: fade-in-up 0.6s ease-out forwards;
        }
        .dark .stop-bg-light { stop-color: #0f172a; }
        .stop-bg-light { stop-color: #f8fafc; }

        /* Custom checkbox styling */
        .custom-checkbox {
            accent-color: #a78bfa;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-100 font-sans min-h-screen flex flex-col transition-colors duration-200">

    <!-- Nav -->
    <nav class="w-full bg-white dark:bg-card-dark py-4 px-6 md:px-12 flex justify-between items-center border-b border-slate-100 dark:border-slate-800 shadow-sm z-10">
        <a href="/" class="text-xl font-medium tracking-tight text-slate-900 dark:text-white no-underline">
            Mini-CMS
        </a>
        <div class="hidden md:flex gap-8 text-sm font-medium text-slate-500 dark:text-slate-400">
        </div>
        <div class="md:hidden">
            <span class="material-icons text-slate-600 dark:text-slate-300">menu</span>
        </div>
    </nav>

    <!-- Main -->
    <main class="grow flex flex-col items-center justify-start pt-24 p-6 relative overflow-hidden">
        <div class="w-full max-w-md bg-white dark:bg-card-dark rounded-3xl shadow-soft p-8 md:p-10 z-10 border border-slate-100 dark:border-slate-700 animate-fade-in-up">
            <div class="mb-8">
                <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-2">Admin Login</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm">Welcome back. Enter your credentials to manage content.</p>
            </div>

            <form id="account" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-2" role="alert"></div>

                <!-- Email -->
                <div>
                    <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
                    <input asp-for="Input.Email"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-shadow"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="Email" />
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Password -->
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label asp-for="Input.Password" class="block text-sm font-medium text-slate-700 dark:text-slate-300"></label>
                    </div>
                    <input asp-for="Input.Password"
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800/50 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-shadow"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="Password" />
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center gap-2">
                    <input asp-for="Input.RememberMe" class="custom-checkbox w-4 h-4 rounded border-slate-300 dark:border-slate-600" />
                    <label asp-for="Input.RememberMe" class="text-sm text-slate-600 dark:text-slate-400">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <!-- Submit -->
                <div class="pt-2">
                    <button id="login-submit" type="submit"
                            class="w-full bg-primary hover:bg-purple-500 text-white font-semibold py-3 px-6 rounded-xl transition-colors duration-200 shadow-lg shadow-purple-500/20 flex justify-center items-center gap-2">
                        <span>Sign In</span>
                        <span class="material-icons text-sm">arrow_forward</span>
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-xs text-slate-400 dark:text-slate-500">
                    Not an admin? <a class="text-slate-600 dark:text-slate-300 hover:text-primary font-medium" href="http://localhost:5173/">Return to Home</a>
                </p>
            </div>
        </div>

        <!-- Decorative Mountains -->
        <div class="w-full flex justify-center mt-12 md:mt-16 opacity-90 pointer-events-none select-none">
            <div class="relative w-full max-w-4xl h-64 md:h-80">
                <svg class="w-full h-full text-blue-100 dark:text-blue-900/20" preserveAspectRatio="none" viewBox="0 0 1000 300" xmlns="http://www.w3.org/2000/svg">
                    <path class="text-blue-50 dark:text-slate-800" d="M0,300 L200,150 L350,220 L500,80 L700,200 L850,120 L1000,300 Z" fill="currentColor"></path>
                    <path class="text-blue-100 dark:text-slate-700 opacity-60" d="M100,300 L300,180 L450,250 L600,150 L800,280 L1000,300 Z" fill="currentColor"></path>
                    <defs>
                        <linearGradient id="mist" x1="0%" x2="0%" y1="0%" y2="100%">
                            <stop class="stop-transparent" offset="0%" style="stop-color:rgb(255,255,255);stop-opacity:0"></stop>
                            <stop class="stop-bg-light dark:stop-bg-dark" offset="100%" style="stop-color:rgb(248,250,252);stop-opacity:1"></stop>
                        </linearGradient>
                    </defs>
                    <rect fill="url(#mist)" height="100%" width="100%"></rect>
                </svg>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full py-6 text-center text-slate-400 dark:text-slate-600 text-xs">
        &copy; 2026 Mini-CMS Project. All rights reserved.
    </footer>

    <!-- Validation scripts required by ASP.NET Identity -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
